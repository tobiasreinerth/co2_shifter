SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
ENTSOE_API_KEY=your_entsoe_security_token_here
# Direct DB connection (Session pooler URI) — only needed for `supabase db push`
SUPABASE_DB_URL=postgresql://postgres.your-project:your_db_password@aws-0-region.pooler.supabase.com:5432/postgres
